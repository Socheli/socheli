# ── Socheli / content-os — environment ──────────────────────────────────────
# Copy to `.env` (git-ignored) and fill in. The engine reads this via env.ts;
# the dashboard reads key PRESENCE (not values) to show connection status.

# ── Media generation ────────────────────────────────────────────────────────
PEXELS_API_KEY=                 # stock B-roll
ELEVENLABS_API_KEY=             # premium voice (omit → Kokoro / premade voices)
ELEVEN_PROXY=            # optional SOCKS5 egress proxy (set only if a provider is blocked in your region)
# any local SOCKS proxy works (e.g. an SSH dynamic-forward); optionally set ELEVEN_SSH_HOST

# ── Brain (LLM backend) ──────────────────────────────────────────────────────
# BRAIN_PROVIDER=claude         # default; claude | openrouter | codex
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# ── YouTube (LIVE) ───────────────────────────────────────────────────────────
# Create an OAuth Desktop client in Google Cloud (YouTube Data API v3 enabled),
# do the one-time consent to mint a refresh token. Uploads route through the
# SOCKS tunnel above (Google may be geo-blocked in some regions). No app review needed for your
# own channel. The tunnel MUST be up for uploads to succeed.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Public video host (REQUIRED for IG + TikTok live) ────────────────────────
# IG Graph API and TikTok ingest a PUBLIC https video URL, never a local file.
# Configure ONE backend (first match wins: local → s3 → put).
#
# Option 0 (our server deploy): local public dir. When publishing runs ON the
# Socheli server, the render already sits in a Caddy-served dir, so no upload —
# the file is copied into HOST_LOCAL_DIR and its public URL is returned.
HOST_LOCAL_DIR=./data/renders
HOST_PUBLIC_BASE=https://media.example.com
#
# Option A: S3-compatible (AWS S3 / Cloudflare R2 / Bunny / MinIO) via `aws` CLI.
HOST_S3_BUCKET=
HOST_S3_PUBLIC_BASE=            # e.g. https://cdn.yourdomain.com  (TikTok: must be a verified domain)
# HOST_S3_ENDPOINT=            # set for R2/Bunny/MinIO; omit for AWS
# HOST_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Option B: a generic signed-PUT endpoint instead of S3.
# HOST_UPLOAD_URL=
# HOST_PUBLIC_BASE=

# ── Instagram Reels (LIVE) ───────────────────────────────────────────────────
# Business/Creator IG linked to a Facebook Page + a Meta app with
# instagram_content_publish (App Review) + a long-lived token (~60-day expiry).
IG_USER_ID=
IG_ACCESS_TOKEN=
# IG_USE_PROXY=1               # only if graph.facebook.com is blocked from this host

# ── TikTok (LIVE) ────────────────────────────────────────────────────────────
# TikTok developer app with the video.publish scope + a user access token.
# Unaudited apps can ONLY post privately (SELF_ONLY); the host domain must be
# verified in the TikTok developer portal for PULL_FROM_URL to work.
TIKTOK_ACCESS_TOKEN=
# TIKTOK_AUDITED=1             # set once your app passes audit → enables public posts

# ── Calendar sync ────────────────────────────────────────────────────────────
# Apple Calendar / any .ics app subscribes to /api/calendar/ics (no creds).
# Optionally gate that public feed with a token (?token=...):
# CALENDAR_ICS_TOKEN=
#
# Google Calendar AUTO-CONNECT (OAuth Desktop client, like YouTube above):
# create an OAuth *Desktop* client in Google Cloud (Calendar API enabled on
# project `<your-gcp-project>`), paste its id/secret below, then connect once:
#   node scripts/mint-google-cal-token.mjs
# That opens consent in your browser and writes GOOGLE_CAL_REFRESH_TOKEN here.
# No app verification needed (you're the test user). Server→Google calls route
# through the SOCKS tunnel above when ELEVEN_PROXY is set (Google may be geo-blocked in some regions).
GOOGLE_CAL_CLIENT_ID=
GOOGLE_CAL_CLIENT_SECRET=
GOOGLE_CAL_REFRESH_TOKEN=      # filled by the mint script — leave blank
# SOCHELI_TZ=Europe/Berlin     # IANA tz for pushed events (default UTC)

# Notion sync: internal integration token + target database id (share the DB
# with the integration first). Pushes the plan into a Notion database view.
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# ── Phone publishing (LIVE — no host, no App Review) ─────────────────────────
# Drive the real social apps on a docked Android over ADB to POST finished
# videos the way a human would. This sidesteps the public-host + App-Review
# gating on IG Reels / TikTok. The agent lives in tools/phone-agent and runs on
# this same Mac (it reads data/runs directly). Setup:
#   brew install android-platform-tools   # adb
#   phone: Developer options → USB debugging (MIUI also: "USB debugging (Security settings)")
#   plug in via USB, accept the prompt, then: node tools/phone-agent/src/run.mjs doctor
PHONE_PUBLISH=                  # set to 1 to route the configured platforms through the phone
# PHONE_PLATFORMS=instagram,tiktok   # which platforms the phone handles (default: instagram,tiktok)
# DEVICE_PIN=                   # numeric lockscreen PIN for unattended auto-unlock (keep this file private)
# PHONE_SERIAL=                 # pin a device when several are attached (`adb devices`)
# ADB_BIN=$ANDROID_HOME/platform-tools/adb
# PHONE_POST_TIMEOUT_MS=300000  # kill a stuck phone post after this long

# ── Agent harness (docs/AGENT-HARNESS.md §3/§7) ──────────────────────────────
# Multi-turn, tool-using agent runtimes. Comma lists = preference order, first
# AVAILABLE runtime wins per tier.
HARNESS_PREMIUM=claude-sdk,claude-code,openrouter   # runtime preference, smart/best tier
HARNESS_DEFAULT=openrouter,claude-code              # cheap tier
ANTHROPIC_API_KEY=            # optional; claude-sdk falls back to Claude Code CLI auth
CODEX_BIN=                    # optional codex CLI path
# HARNESS_OPENROUTER_MODEL=   # optional; TOOL-CAPABLE model for the harness tool
                              # loop (overrides OPENROUTER_MODEL, which may be a
                              # no-tools model picked for the one-shot brain)

# ── Brand Genome (docs/AGENT-HARNESS.md §1) ──────────────────────────────────
ICOG_API_KEY=                 # optional: mirror applied genome mutations to iCog
# ICOG_API_URL=https://api.cognitivx.io   # override the iCog API base
# ICOG_AGENT_SLUG=socheli-soli             # iCog agent the memories belong to

# ── Research harness (docs/AGENT-HARNESS.md §2) ──────────────────────────────
RESEARCH_MAX_USD=             # optional per-run research budget; unset/0 = unlimited.
                              # When crossed mid-run the orchestrator stops expanding
                              # and synthesizes with what it has.

# ── AI video b-roll generators (optional — activates AI-generated footage for abstract scenes)
KLING_API_KEY=           # Kling AI v2.6-pro text-to-video
PIKA_API_KEY=            # Pika v2.2 via fal.ai (or set FAL_API_KEY)
FAL_API_KEY=             # fal.ai key (alternative to PIKA_API_KEY)
MINIMAX_API_KEY=         # Minimax Hailuo T2V-01-Director
LUMALABS_API_KEY=        # Luma Dream Machine ray-2
